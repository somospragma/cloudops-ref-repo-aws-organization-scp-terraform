      "Action": [
        "events:PutRule",
        "bedrock:CreateGuardrail",
        "ec2:CreateTransitGateway",
        "ec2:CreateVpnConnection"
      ],
      "Resource": "*",
      "Condition": {
        "StringNotEqualsIfExists": {
          "aws:RequestTag/territory": ["colombia", "eeuu", "mexico", "cac", "global"]
        }
      }
    },
    {
      "Sid": "DenyMissingTerritoryTag",
      "Effect": "Deny",
      "Action": [
        "events:PutRule",
        "bedrock:CreateGuardrail",
        "ec2:CreateTransitGateway",
        "ec2:CreateVpnConnection"
      ],
