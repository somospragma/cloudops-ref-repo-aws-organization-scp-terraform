        "Null": { "aws:RequestTag/owner": "true" }
      }
    },
    {
      "Sid": "DenyInvalidCostCenterTag",
      "Effect": "Deny",
      "Action": [
        "events:PutRule",
        "bedrock:CreateGuardrail",
        "ec2:CreateTransitGateway",
        "ec2:CreateVpnConnection"
      ],
      "Resource": "*",
      "Condition": {
        "StringNotEqualsIfExists": {
          "aws:RequestTag/cost-center": "9952"
        }
      }
    },
    {
      "Sid": "DenyMissingCostCenterTag",
      "Effect": "Deny",
      "Action": [
        "events:PutRule",
        "bedrock:CreateGuardrail",
        "ec2:CreateTransitGateway",
        "ec2:CreateVpnConnection"
      ],
      "Resource": "*",
      "Condition": {
