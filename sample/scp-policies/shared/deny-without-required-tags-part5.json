{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DenyInvalidProjectTag",
      "Effect": "Deny",
      "Action": [
        "events:PutRule",
        "bedrock:CreateGuardrail",
        "ec2:CreateTransitGateway",
        "ec2:CreateVpnConnection"
      ],
      "Resource": "*",
      "Condition": {
        "StringNotEqualsIfExists": {
          "aws:RequestTag/project": ["sopp-dev", "sopp-poc", "sopp-prod"]
        }
      }
    },
    {
      "Sid": "DenyMissingProjectTag",
      "Effect": "Deny",
      "Action": [
        "events:PutRule",
        "bedrock:CreateGuardrail",
        "ec2:CreateTransitGateway",
        "ec2:CreateVpnConnection"
      ],
      "Resource": "*",
      "Condition": {
        "Null": { "aws:RequestTag/project": "true" }
      }
    },
    {
      "Sid": "DenyInvalidEnvironmentTag",
      "Effect": "Deny",
      "Action": [
        "events:PutRule",
        "bedrock:CreateGuardrail",
        "ec2:CreateTransitGateway",
        "ec2:CreateVpnConnection"
      ],
      "Resource": "*",
      "Condition": {
        "StringNotEqualsIfExists": {
          "aws:RequestTag/environment": ["dev", "poc", "prod"]
        }
      }
    },
    {
      "Sid": "DenyMissingEnvironmentTag",
      "Effect": "Deny",
      "Action": [
        "events:PutRule",
        "bedrock:CreateGuardrail",
        "ec2:CreateTransitGateway",
        "ec2:CreateVpnConnection"
      ],
      "Resource": "*",
      "Condition": {
        "Null": { "aws:RequestTag/environment": "true" }
      }
    },
    {
      "Sid": "DenyInvalidTerritoryTag",
