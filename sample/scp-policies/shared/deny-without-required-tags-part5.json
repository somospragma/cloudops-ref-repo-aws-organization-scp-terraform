        "Null": { "aws:RequestTag/territory": "true" }
      }
    },
    {
      "Sid": "DenyInvalidCountryTag",
      "Effect": "Deny",
      "Action": [
        "events:PutRule",
        "bedrock:CreateGuardrail",
        "ec2:CreateTransitGateway",
        "ec2:CreateVpnConnection"
      ],
      "Resource": "*",
      "Condition": {
        "StringNotEqualsIfExists": {
          "aws:RequestTag/country": ["colombia", "panama", "guatemala", "costa-rica", "mexico", "eeuu", "honduras", "global"]
        }
      }
    },
    {
      "Sid": "DenyMissingCountryTag",
      "Effect": "Deny",
      "Action": [
        "events:PutRule",
        "bedrock:CreateGuardrail",
        "ec2:CreateTransitGateway",
        "ec2:CreateVpnConnection"
      ],
      "Resource": "*",
      "Condition": {
        "Null": { "aws:RequestTag/country": "true" }
      }
    },
    {
      "Sid": "DenyMissingClienteTag",
      "Effect": "Deny",
      "Action": [
        "events:PutRule",
        "bedrock:CreateGuardrail",
