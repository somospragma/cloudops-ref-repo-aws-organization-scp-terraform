{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DenyInvalidCostCenterTag",
      "Effect": "Deny",
      "Action": [
        "ec2:RunInstances","ec2:CreateVolume","ec2:CreateVpc","ec2:CreateSubnet",
        "ec2:CreateSecurityGroup","ec2:CreateNatGateway","ec2:CreateInternetGateway",
        "ec2:AllocateAddress","ec2:CreateTransitGateway","ec2:CreateVpnConnection",
        "rds:CreateDBInstance","rds:CreateDBCluster","s3:CreateBucket",
        "lambda:CreateFunction","ecs:CreateCluster","ecs:CreateService",
        "elasticloadbalancing:CreateLoadBalancer","dynamodb:CreateTable",
        "sqs:CreateQueue","sns:CreateTopic","logs:CreateLogGroup","kms:CreateKey",
        "secretsmanager:CreateSecret","eks:CreateCluster","iam:CreateRole",
        "iam:CreateUser","bedrock-agentcore:Create*","cloudfront:CreateDistribution",
        "cognito-idp:CreateUserPool","ecr:CreateRepository","kinesis:CreateStream",
        "wafv2:CreateWebACL","events:PutRule","bedrock:CreateGuardrail"
      ],
      "Resource": "*",
      "Condition": {
        "StringNotEqualsIfExists": {
          "aws:RequestTag/cost-center": "9952"
        }
      }
    },
    {
      "Sid": "DenyMissingCostCenterTag",
      "Effect": "Deny",
      "Action": [
        "ec2:RunInstances","ec2:CreateVolume","ec2:CreateVpc","ec2:CreateSubnet",
        "ec2:CreateSecurityGroup","ec2:CreateNatGateway","ec2:CreateInternetGateway",
        "ec2:AllocateAddress","ec2:CreateTransitGateway","ec2:CreateVpnConnection",
        "rds:CreateDBInstance","rds:CreateDBCluster","s3:CreateBucket",
        "lambda:CreateFunction","ecs:CreateCluster","ecs:CreateService",
        "elasticloadbalancing:CreateLoadBalancer","dynamodb:CreateTable",
        "sqs:CreateQueue","sns:CreateTopic","logs:CreateLogGroup","kms:CreateKey",
        "secretsmanager:CreateSecret","eks:CreateCluster","iam:CreateRole",
        "iam:CreateUser","bedrock-agentcore:Create*","cloudfront:CreateDistribution",
        "cognito-idp:CreateUserPool","ecr:CreateRepository","kinesis:CreateStream",
        "wafv2:CreateWebACL","events:PutRule","bedrock:CreateGuardrail"
      ],
      "Resource": "*",
      "Condition": {
        "Null": {"aws:RequestTag/cost-center": "true"}
      }
    },
    {
      "Sid": "DenyMissingOwnerTag",
      "Effect": "Deny",
      "Action": [
        "ec2:RunInstances","ec2:CreateVolume","ec2:CreateVpc","ec2:CreateSubnet",
        "ec2:CreateSecurityGroup","ec2:CreateNatGateway","ec2:CreateInternetGateway",
        "ec2:AllocateAddress","ec2:CreateTransitGateway","ec2:CreateVpnConnection",
        "rds:CreateDBInstance","rds:CreateDBCluster","s3:CreateBucket",
        "lambda:CreateFunction","ecs:CreateCluster","ecs:CreateService",
        "elasticloadbalancing:CreateLoadBalancer","dynamodb:CreateTable",
        "sqs:CreateQueue","sns:CreateTopic","logs:CreateLogGroup","kms:CreateKey",
        "secretsmanager:CreateSecret","eks:CreateCluster","iam:CreateRole",
        "iam:CreateUser","bedrock-agentcore:Create*","cloudfront:CreateDistribution",
        "cognito-idp:CreateUserPool","ecr:CreateRepository","kinesis:CreateStream",
        "wafv2:CreateWebACL","events:PutRule","bedrock:CreateGuardrail"
      ],
      "Resource": "*",
      "Condition": {
        "Null": {"aws:RequestTag/owner": "true"}
      }
    }
  ]
}
