{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DenyInvalidProjectTag",
      "Effect": "Deny",
      "Action": [
        "ec2:RunInstances",
        "ec2:CreateVolume",
        "ec2:CreateVpc",
        "ec2:CreateSubnet",
        "ec2:CreateSecurityGroup",
        "ec2:CreateNatGateway",
        "ec2:AllocateAddress",
        "rds:CreateDBInstance",
        "rds:CreateDBCluster",
        "s3:CreateBucket",
        "lambda:CreateFunction",
        "ecs:CreateCluster",
        "ecs:CreateService",
        "elasticloadbalancing:CreateLoadBalancer",
        "dynamodb:CreateTable",
        "sqs:CreateQueue",
        "sns:CreateTopic",
        "logs:CreateLogGroup",
        "kms:CreateKey",
        "secretsmanager:CreateSecret",
        "eks:CreateCluster",
        "iam:CreateRole",
        "iam:CreateUser",
        "bedrock-agentcore:Create*",
        "cloudfront:CreateDistribution",
        "cognito-idp:CreateUserPool"
      ],
      "Resource": "*",
      "Condition": {
        "StringNotEqualsIfExists": {
          "aws:RequestTag/project": [
            "sopp-dev",
            "sopp-poc",
            "sopp-prod"
          ]
        }
      }
    },
    {
      "Sid": "DenyMissingProjectTag",
      "Effect": "Deny",
      "Action": [
        "ec2:RunInstances",
        "ec2:CreateVolume",
        "ec2:CreateVpc",
        "ec2:CreateSubnet",
        "ec2:CreateSecurityGroup",
        "ec2:CreateNatGateway",
        "ec2:AllocateAddress",
        "rds:CreateDBInstance",
        "rds:CreateDBCluster",
        "s3:CreateBucket",
        "lambda:CreateFunction",
        "ecs:CreateCluster",
        "ecs:CreateService",
        "elasticloadbalancing:CreateLoadBalancer",
        "dynamodb:CreateTable",
        "sqs:CreateQueue",
        "sns:CreateTopic",
        "logs:CreateLogGroup",
        "kms:CreateKey",
        "secretsmanager:CreateSecret",
        "eks:CreateCluster",
        "iam:CreateRole",
        "iam:CreateUser",
        "bedrock-agentcore:Create*",
        "cloudfront:CreateDistribution",
        "cognito-idp:CreateUserPool"
      ],
      "Resource": "*",
      "Condition": {
        "Null": {
          "aws:RequestTag/project": "true"
        }
      }
    },
    {
      "Sid": "DenyInvalidEnvironmentTag",
      "Effect": "Deny",
      "Action": [
        "ec2:RunInstances",
        "ec2:CreateVolume",
        "ec2:CreateVpc",
        "ec2:CreateSubnet",
        "ec2:CreateSecurityGroup",
        "ec2:CreateNatGateway",
        "ec2:AllocateAddress",
        "rds:CreateDBInstance",
        "rds:CreateDBCluster",
        "s3:CreateBucket",
        "lambda:CreateFunction",
        "ecs:CreateCluster",
        "ecs:CreateService",
        "elasticloadbalancing:CreateLoadBalancer",
        "dynamodb:CreateTable",
        "sqs:CreateQueue",
        "sns:CreateTopic",
        "logs:CreateLogGroup",
        "kms:CreateKey",
        "secretsmanager:CreateSecret",
        "eks:CreateCluster",
        "iam:CreateRole",
        "iam:CreateUser",
        "bedrock-agentcore:Create*",
        "cloudfront:CreateDistribution",
        "cognito-idp:CreateUserPool"
      ],
      "Resource": "*",
      "Condition": {
        "StringNotEqualsIfExists": {
          "aws:RequestTag/environment": [
            "dev",
            "poc",
            "prod"
          ]
        }
      }
    },
    {
      "Sid": "DenyMissingEnvironmentTag",
      "Effect": "Deny",
      "Action": [
        "ec2:RunInstances",
        "ec2:CreateVolume",
        "ec2:CreateVpc",
        "ec2:CreateSubnet",
        "ec2:CreateSecurityGroup",
        "ec2:CreateNatGateway",
        "ec2:AllocateAddress",
        "rds:CreateDBInstance",
        "rds:CreateDBCluster",
        "s3:CreateBucket",
        "lambda:CreateFunction",
        "ecs:CreateCluster",
        "ecs:CreateService",
        "elasticloadbalancing:CreateLoadBalancer",
        "dynamodb:CreateTable",
        "sqs:CreateQueue",
        "sns:CreateTopic",
        "logs:CreateLogGroup",
        "kms:CreateKey",
        "secretsmanager:CreateSecret",
        "eks:CreateCluster",
        "iam:CreateRole",
        "iam:CreateUser",
        "bedrock-agentcore:Create*",
        "cloudfront:CreateDistribution",
        "cognito-idp:CreateUserPool"
      ],
      "Resource": "*",
      "Condition": {
        "Null": {
          "aws:RequestTag/environment": "true"
        }
      }
    }
  ]
}
